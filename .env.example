# ─── CONVEX ───────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
CONVEX_DEPLOY_KEY=your_convex_deploy_key

# ─── APP ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://guarujaguias.com.br

# ─── CLOUDFLARE IMAGES ────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cf_account_id
CLOUDFLARE_IMAGES_TOKEN=your_cf_images_api_token
NEXT_PUBLIC_CF_IMAGES_HASH=your_cf_images_delivery_hash
# Format: https://imagedelivery.net/{HASH}/{image_id}/{variant}

# ─── MERCADOPAGO ──────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx  # Use PROD- prefix in production
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxx

# ─── AUTH (Convex Auth) ───────────────────────────────────
AUTH_SECRET=your_32_char_random_secret

# ─── OPTIONAL: GOOGLE MAPS (for geocoding during registration) ──
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_key_here

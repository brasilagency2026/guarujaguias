# ─── CONVEX ───────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
CONVEX_DEPLOY_KEY=your_convex_deploy_key

# ─── APP ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://guarujaguias.com.br

# ─── CLERK AUTH ───────────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# Clerk redirect URLs (optional — defaults work fine)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/registro
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/cadastro

# ─── CLOUDFLARE IMAGES ────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cf_account_id
CLOUDFLARE_IMAGES_TOKEN=your_cf_images_api_token
NEXT_PUBLIC_CF_IMAGES_HASH=your_cf_images_delivery_hash

# ─── MERCADOPAGO ──────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-xxxx
